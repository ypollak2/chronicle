{
  "name": "chronicle-dev",
  "version": "0.1.0",
  "description": "CLI for Chronicle — AI-native development memory",
  "type": "module",
  "bin": {
    "chronicle": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --banner.js '#!/usr/bin/env node'",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@chronicle/core": "*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
