{
  "name": "@chronicle/core",
  "version": "1.0.0",
  "description": "Core store logic for Chronicle",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./unstable": {
      "import": "./dist/unstable.js",
      "require": "./dist/unstable.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/unstable.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.0.1"
  }
}
